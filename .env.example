NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Public site URL — used for sitemap, robots.txt, and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps JavaScript API key (restrict to Maps JavaScript API in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Optional: custom Map ID for Advanced Markers (defaults to DEMO_MAP_ID)
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_map_id_here

# Legacy alias (still supported)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google reCAPTCHA v2 site key (optional in dev)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
